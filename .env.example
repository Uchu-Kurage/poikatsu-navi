# collector（キャンペーン自動収集）用の環境変数の例。
# ローカル実行時は .env にコピーして値を設定してください（.env はコミットされません）。

# Claude API キー（必須）
ANTHROPIC_API_KEY=

# 抽出モデル（任意。既定: claude-opus-4-8 / コスト重視: claude-haiku-4-5）
# COLLECTOR_MODEL=claude-opus-4-8

# 追加フィード（任意・カンマ区切り）
# COLLECTOR_FEEDS=https://example.com/feed1,https://example.com/feed2

# 抽出上限・掃除日数（任意）
# COLLECTOR_MAX_ITEMS=50
# COLLECTOR_PRUNE_DAYS=60
